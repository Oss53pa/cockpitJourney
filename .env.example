# CockpitJourney — environment configuration
# Copy this file to `.env.local` and fill in your own values.

# ── Supabase (database + auth) ─────────────────────────────────────────
# Get these from https://supabase.com/dashboard/project/<your-project>/settings/api
# - URL: "Project URL"
# - anon key: "Project API keys" → "anon" (or modern publishable key starting with sb_publishable_)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# ── Atlas Studio « Proph3t core » (cœur IA mutualisé) ──────────────────
# Branche l'app au cœur Proph3t (mémoire inter-apps, RAG SYSCOHADA, 197
# outils, audit SHA-256, orchestrateur hébergé). Ces variables pointent sur
# le projet CORE Atlas Studio — PAS forcément le Supabase de l'app.
# Pour CockpitJourney (qui tourne déjà sur le core), ce sont les MÊMES valeurs
# que VITE_SUPABASE_* ci-dessus. Ne committez JAMAIS la clé : .env.local only.
# Si non définies, src/lib/proph3tCore.ts retombe sur VITE_SUPABASE_*.
VITE_ATLAS_SUPABASE_URL=https://vgtmljfayiysuvrcmunt.supabase.co
VITE_ATLAS_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# ── Sentry (error monitoring — optional but strongly recommended in prod) ──
# Get the DSN from https://sentry.io/settings/<org>/projects/<project>/keys/
# Leave empty in local dev — Sentry will no-op and the SDK won't be loaded.
VITE_SENTRY_DSN=

# Optional: commit SHA / release tag, used to group errors by deployment.
# In Vercel, set this to "$VERCEL_GIT_COMMIT_SHA" so each deploy is tagged.
VITE_RELEASE_SHA=
