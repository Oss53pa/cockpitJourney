{
  "name": "cockpitjourney",
  "private": true,
  "version": "1.0.0",
  "description": "CockpitJourney — Pilotez votre journée. Compagnon quotidien de gestion de tâches et projets, propulsé par PROPH3T (Atlas Studio).",
  "author": "Pamela Atokouna · Atlas Studio",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --port 5400",
    "preview:host": "vite preview --port 5400 --host 0.0.0.0",
    "start": "vite preview --port 5400 --open",
    "start:fresh": "vite build && vite preview --port 5400 --open",
    "lint": "eslint .",
    "type-check": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "analyze": "vite build",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "dexie": "^4.4.2",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.35",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vitest": "^1.6.1"
  }
}
